# 本地开发环境建议配置
# 复制为 .env.local 或 .env，并按需修改

# 必填：管理后台密码
CCLOAD_PASS=dev_password_change_me

# 本地 SQLite 数据文件
SQLITE_PATH=./data/ccload-dev.db

# 本地开发端口
PORT=8080

# 开发期建议保留 release，除非你明确要看 Gin debug 输出
GIN_MODE=release

# 可选：限制本地并发，便于调试
# CCLOAD_MAX_CONCURRENCY=200

# 可选：启动时预置访问令牌
# CCLOAD_API_TOKENS=dev-token|local-development

# 可选：容器 / 网络盘环境下可切换 journal 模式
# SQLITE_JOURNAL_MODE=TRUNCATE

# 严禁默认开启，仅排障时短期开
# CCLOAD_ALLOW_INSECURE_TLS=0

